// FILE 5: GrievanceReport.java
// Tracks vendor complaints  replaces the political voice lost
// when elected KCC was replaced by appointed KCCA (Young, 2017)
// OOP: ENCAPSULATION
// 

public class GrievanceReport {

    // Grievance type constants
    public static final String TYPE_UNFAIR_EVICTION    = "UNFAIR_EVICTION";
    public static final String TYPE_SPACE_UNAVAILABLE  = "SPACE_UNAVAILABLE";
    public static final String TYPE_OFFICER_MISCONDUCT = "OFFICER_MISCONDUCT";
    public static final String TYPE_OTHER              = "OTHER";

    // Status constants
    public static final String STATUS_OPEN         = "OPEN";
    public static final String STATUS_UNDER_REVIEW = "UNDER_REVIEW";
    public static final String STATUS_RESOLVED     = "RESOLVED";

    // Private fields (Encapsulation)
    private String grievanceID;
    private String vendorID;
    private String vendorName;
    private String type;
    private String details;
    private String dateSubmitted;
    private String status;
    private String resolutionNotes;   // filled by Administrator on resolve

    // Constructor
    public GrievanceReport(String grievanceID, Vendor vendor, String type, String details) {
        this.grievanceID     = grievanceID;
        this.vendorID        = vendor.getEntityID();
        this.vendorName      = vendor.getName();
        this.type            = type;
        this.details         = details;
        this.dateSubmitted   = java.time.LocalDate.now().toString();
        this.status          = STATUS_OPEN;
        this.resolutionNotes = null;
        System.out.println("Grievance " + grievanceID + " submitted by " + vendorName);
    }

    // Update grievance status  Administrators only (enforced by VendorManagementSystem)
    public void updateStatus(String newStatus, String notes) {
        this.status          = newStatus;
        this.resolutionNotes = notes;
        System.out.println("Grievance " + grievanceID + " updated to: " + newStatus);
    }

    // Display grievance summary
    public void displaySummary() {
        System.out.println("[" + grievanceID + "] " + type + " | " + status);
        System.out.println("  Vendor  : " + vendorName + " (" + vendorID + ")");
        System.out.println("  Date    : " + dateSubmitted);
        System.out.println("  Details : " + details);
        if (resolutionNotes != null)
            System.out.println("  Notes   : " + resolutionNotes);
    }

    // Getters
    public String getGrievanceID()   { return grievanceID; }
    public String getVendorID()      { return vendorID; }
    public String getType()          { return type; }
    public String getStatus()        { return status; }
    public String getDateSubmitted() { return dateSubmitted; }
}


