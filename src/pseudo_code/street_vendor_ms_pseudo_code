// FILE 7: VendorManagementSystem.java
// Main controller — orchestrates all KSVMS operations
// OOP: Composition, Polymorphism, Stream API
// 

import java.util.ArrayList;
import java.util.List;
import java.util.stream.Collectors;

public class VendorManagementSystem {

    // Core data stores
    private List<Vendor>          vendors    = new ArrayList<>();
    private List<MarketSpace>     spaces     = new ArrayList<>();
    private List<KCCAOfficial>    officials  = new ArrayList<>();
    private List<GrievanceReport> grievances = new ArrayList<>();
    private int                   grievanceCounter = 1;

    //  SECTION A: ADD ENTITIES 

    public void addVendor(Vendor v)        { vendors.add(v); }
    public void addMarketSpace(MarketSpace s) { spaces.add(s); }
    public void addOfficial(KCCAOfficial o) { officials.add(o); }

    //  SECTION B: VENDOR OPERATIONS 

    // Register all pending vendors
    public void registerAllVendors() {
        for (Vendor vendor : vendors) {
            if (vendor.getStatus().equals("UNREGISTERED")) {
                vendor.register();
            }
        }
    }

    // Search vendors by name, ID, type, or assigned market
    public List<Vendor> searchVendors(String keyword) {
        String kw = keyword.toLowerCase();
        return vendors.stream()
            .filter(v -> v.getName().toLowerCase().contains(kw)
                      || v.getEntityID().toLowerCase().contains(kw)
                      || v.getVendorType().toLowerCase().contains(kw)
                      || (v.getAssignedMarket() != null &&
                          v.getAssignedMarket().toLowerCase().contains(kw)))
            .collect(Collectors.toList());
    }

    // Update vendor status — Administrator only
    public void updateVendorStatus(KCCAOfficial officer, String vendorID, String newStatus) {
        if (!officer.canAccessAdminFunctions()) {
            System.out.println("Access denied: only Administrators can update vendor status.");
            return;
        }
        for (Vendor v : vendors) {
            if (v.getEntityID().equals(vendorID)) {
                v.setStatus(newStatus);
                AuditLog.record(officer.getEntityID(), "STATUS_UPDATE", vendorID, newStatus);
                System.out.println("Vendor " + vendorID + " status updated to: " + newStatus);
                return;
            }
        }
        System.out.println("Vendor not found: " + vendorID);
    }

    //  SECTION C: SMART SPACE MATCHING 

    // Find the best available space for a vendor based on capital
    // and gender priority score (Whitesell et al. 2025)
    public MarketSpace findBestSpace(Vendor vendor) {
        return spaces.stream()
            .filter(s -> !s.isOccupied()
                      && s.getMonthlyRent() <= vendor.getCapitalAmount())
            .sorted((a, b) -> Double.compare(a.getMonthlyRent(), b.getMonthlyRent()))
            .findFirst()
            .orElse(null);
    }

    // Auto-allocate all unassigned vendors to best available spaces
    public void autoAllocateAll() {
        System.out.println("\n Auto-Allocation Starting ");
        for (Vendor vendor : vendors) {
            if (vendor.getAssignedMarket()  null) {
                MarketSpace best = findBestSpace(vendor);
                if (best != null) {
                    best.assignVendor(vendor);
                } else {
                    System.out.println("No affordable space found for: " + vendor.getName()
                                     + " (Capital: UGX " + vendor.getCapitalAmount() + ")");
                }
            }
        }
        System.out.println(" Auto-Allocation Complete \n");
    }

    //  SECTION D: GRIEVANCE MANAGEMENT 

    // Submit a grievance on behalf of a vendor
    public void submitGrievance(Vendor vendor, String type, String details) {
        String gID = "GRV-" + String.format("%04d", grievanceCounter++);
        GrievanceReport report = new GrievanceReport(gID, vendor, type, details);
        grievances.add(report);
    }

    // Resolve a grievance — Administrator only
    public void resolveGrievance(KCCAOfficial officer, String grievanceID, String notes) {
        if (!officer.canAccessAdminFunctions()) {
            System.out.println("Access denied: Administrators only.");
            return;
        }
        for (GrievanceReport g : grievances) {
            if (g.getGrievanceID().equals(grievanceID)) {
                g.updateStatus(GrievanceReport.STATUS_RESOLVED, notes);
                AuditLog.record(officer.getEntityID(), "RESOLVE_GRIEVANCE", grievanceID, notes);
                return;
            }
        }
        System.out.println("Grievance not found: " + grievanceID);
    }

    // Print all open grievances (pass null to show all types)
    public void printGrievanceReport(String filterType) {
        System.out.println("\n= GRIEVANCE REPORT =");
        grievances.stream()
            .filter(g -> filterType  null || g.getType().equals(filterType))
            .filter(g -> !g.getStatus().equals(GrievanceReport.STATUS_RESOLVED))
            .forEach(GrievanceReport::displaySummary);
        System.out.println("\n");
    }

    //  SECTION E: REPORTING & ANALYTICS 

    // Display all profiles Polymorphism: same method call, different output
    public void displayAllProfiles() {
        System.out.println("\n= ALL VENDOR PROFILES ");
        vendors.forEach(CustomUser::displayProfile);    // Polymorphic call
        System.out.println("\n= ALL OFFICER PROFILES =");
        officials.forEach(CustomUser::displayProfile);  // Same method, different output
    }

    // Strategic market occupancy report
    public void generateStrategicReport() {
        long   totalVendors   = vendors.size();
        long   activeVendors  = vendors.stream().filter(v -> v.getRawStatus().equals("ACTIVE")).count();
        long   femaleVendors  = vendors.stream().filter(v -> v.getGender().equalsIgnoreCase("F")).count();
        long   occupied       = spaces.stream().filter(MarketSpace::isOccupied).count();
        long   available      = spaces.size() - occupied;
        double occupancyRate  = spaces.isEmpty() ? 0 : (double) occupied / spaces.size() * 100;
        double monthlyRevenue = spaces.stream()
            .filter(MarketSpace::isOccupied)
            .mapToDouble(MarketSpace::getMonthlyRent).sum();

        System.out.println("\n= KCCA STRATEGIC REPORT =");
        System.out.println("  Total Registered Vendors  : " + totalVendors);
        System.out.println("  Active Vendors            : " + activeVendors);
        System.out.println("  Female Vendors            : " + femaleVendors
                         + " (" + (totalVendors > 0 ? femaleVendors * 100 / totalVendors : 0) + "%)");
        System.out.println("  Market Occupancy Rate     : " + String.format("%.1f", occupancyRate) + "%");
        System.out.println("  Spaces Occupied           : " + occupied);
        System.out.println("  Spaces Available          : " + available);
        System.out.println("  Est. Monthly Revenue (UGX): " + monthlyRevenue);
        System.out.println("  Open Grievances           : " +
            grievances.stream().filter(g -> g.getStatus().equals(GrievanceReport.STATUS_OPEN)).count());
        System.out.println("=\n");
    }

    // List vendors not yet assigned to a market space
    public void printUnmatchedVendors() {
        System.out.println("\n= UNMATCHED VENDORS =");
        vendors.stream()
            .filter(v -> v.getAssignedMarket()  null)
            .sorted((a, b) -> Double.compare(b.getPriorityScore(), a.getPriorityScore()))
            .forEach(v -> System.out.println(
                "  " + v.getEntityID()
                + " | " + v.getName()
                + " | Capital: UGX " + v.getCapitalAmount()
                + " | Priority Score: " + v.getPriorityScore()));
        System.out.println("=\n");
    }
}


