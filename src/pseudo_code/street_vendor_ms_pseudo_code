// FILE 6: AuditLog.java
// Immutable log of all system actions — anti-corruption measure
// OOP: Static utility class, ENCAPSULATION
// 

import java.util.ArrayList;
import java.util.List;

public class AuditLog {

    // Static singleton log — cannot be deleted by normal users
    private static final List<String> log = new ArrayList<>();

    // Record an action
    public static void record(String officerID, String action,
                               String targetID, String notes) {
        String timestamp = java.time.LocalDateTime.now().toString();
        String entry = "[" + timestamp + "]"
                     + " Officer:" + officerID
                     + " | Action:" + action
                     + " | Target:" + targetID
                     + " | Notes:"  + notes;
        log.add(entry);
        System.out.println("AUDIT: " + entry);
    }

    // Print full audit trail
    public static void printFullLog() {
        System.out.println("= FULL AUDIT LOG =");
        if (log.isEmpty()) {
            System.out.println("  No entries recorded.");
        } else {
            for (String entry : log) {
                System.out.println(entry);
            }
        }
        System.out.println("");
    }

    // Get total log entry count
    public static int getLogCount() { return log.size(); }

    // Private constructor — prevents instantiation
    private AuditLog() {}
}


