// FILE 1: CustomUser.java
// Abstract base class — defines contract for ALL system users
// OOP: ABSTRACTION, ENCAPSULATION
// 

public abstract class CustomUser {

    // Private fields (Encapsulation)
    private String  entityID;
    private String  name;
    private String  email;
    private String  passwordHash;
    private String  status;           // "PENDING" | "ACTIVE" | "SUSPENDED"
    private String  dateRegistered;

    // Constructor
    public CustomUser(String entityID, String name, String email, String passwordHash) {
        this.entityID      = entityID;
        this.name          = name;
        this.email         = email;
        this.passwordHash  = passwordHash;
        this.status        = "PENDING";
        this.dateRegistered = java.time.LocalDate.now().toString();
    }

    // Abstract methods — all subclasses MUST implement (Abstraction)
    public abstract void   register();
    public abstract String getStatus();
    public abstract void   displayProfile();
    public abstract String getRole();     // "VENDOR" | "INSPECTOR" | "ADMINISTRATOR"

    // Authentication
    public boolean login(String email, String passwordHash) {
        if (this.email.equals(email) && this.passwordHash.equals(passwordHash)) {
            System.out.println("Login successful: " + name);
            return true;
        }
        System.out.println("Invalid credentials.");
        return false;
    }

    // Getters & Setters (Encapsulation)
    public String getEntityID()              { return entityID; }
    public String getName()                  { return name; }
    public String getEmail()                 { return email; }
    public String getDateRegistered()        { return dateRegistered; }
    public void   setStatus(String status)   { this.status = status; }
    public String getRawStatus()             { return status; }
}


