public class KCCAOfficial extends CustomUser {

    // Role constants
    public static final String ROLE_INSPECTOR     = "INSPECTOR";
    public static final String ROLE_ADMINISTRATOR = "ADMINISTRATOR";

    // Private fields
    private String role;          // ROLE_INSPECTOR | ROLE_ADMINISTRATOR
    private String assignedZone;  // e.g. "CBD", "Nakawa", "Kawempe"
    private String badgeNumber;

    // Constructor
    public KCCAOfficial(String id, String name, String email,
                        String passwordHash, String role, String zone) {
        super(id, name, email, passwordHash);
        this.role         = role;
        this.assignedZone = zone;
        this.badgeNumber  = "KCA-" + id;
    }

    // register() — overrides CustomUser (Polymorphism)
    @Override
    public void register() {
        setStatus("ACTIVE");
        System.out.println("Officer registered: " + getName() + " | Role: " + role);
        System.out.println("Badge: " + badgeNumber + " | Zone: " + assignedZone);
    }

    // displayProfile() — overrides CustomUser (Polymorphism)
    @Override
    public void displayProfile() {
        System.out.println("= KCCA OFFICER PROFILE =");
        System.out.println("  ID      : " + getEntityID());
        System.out.println("  Name    : " + getName());
        System.out.println("  Role    : " + role);
        System.out.println("  Badge   : " + badgeNumber);
        System.out.println("  Zone    : " + assignedZone);
        System.out.println("  Status  : " + getStatus());
    }

    // getStatus() — overrides CustomUser (Polymorphism)
    @Override
    public String getStatus() { return "OFFICIAL — " + getRawStatus(); }

    // getRole() — overrides CustomUser
    @Override
    public String getRole() { return role; }

    // Role-Based Access Control helpers
    public boolean canAccessAdminFunctions() {
        return role.equals(ROLE_ADMINISTRATOR);
    }

    public boolean canAssignSpaces() {
        return role.equals(ROLE_INSPECTOR) || role.equals(ROLE_ADMINISTRATOR);
    }

    // Officer-led vendor relocation
    public void relocateVendor(Vendor vendor, MarketSpace space) {
        if (!canAssignSpaces()) {
            System.out.println("Access denied: insufficient role permissions.");
            return;
        }
        System.out.println(role + " " + getName() + " relocating: " + vendor.getName());
        boolean success = space.assignVendor(vendor);
        if (success) {
            vendor.register();
            AuditLog.record(getEntityID(), "RELOCATE", vendor.getEntityID(), space.getSpaceID());
        }
    }

    // Getters
    public String getAssignedZone() { return assignedZone; }
    public String getBadgeNumber()  { return badgeNumber; }
}


