// FILE 2: Vendor.java
// Represents a street vendor seeking or holding a market stall
// OOP: INHERITANCE (extends CustomUser), POLYMORPHISM
// 

public class Vendor extends CustomUser {

    // Additional private fields
    private String  vendorType;         // "Food" | "Clothing" | "Electronics" | "Other"
    private double  capitalAmount;      // in UGX
    private String  gender;             // "F" | "M" | "Other"
    private boolean hasDependants;
    private String  placeOfResidence;
    private String  dateOfBirth;
    private String  assignedMarket;     // null until allocated
    private String  licenceNumber;      // null until registered

    // Constructor
    public Vendor(String id, String name, String email, String passwordHash,
                  String vendorType, double capitalAmount,
                  String gender, boolean hasDependants,
                  String residence, String dob) {

        super(id, name, email, passwordHash);   // call CustomUser constructor
        this.vendorType       = vendorType;
        this.capitalAmount    = capitalAmount;
        this.gender           = gender;
        this.hasDependants    = hasDependants;
        this.placeOfResidence = residence;
        this.dateOfBirth      = dob;
        this.assignedMarket   = null;
        this.licenceNumber    = null;
    }

    // register() — overrides CustomUser (Polymorphism)
    @Override
    public void register() {
        int currentYear    = java.time.LocalDate.now().getYear();
        this.licenceNumber = "KCCA-" + getEntityID() + "-" + currentYear;
        setStatus("ACTIVE");
        System.out.println("Vendor registered successfully.");
        System.out.println("Licence Number : " + licenceNumber);
        System.out.println("Status         : " + getStatus());
    }

    // displayProfile() — overrides CustomUser (Polymorphism)
    @Override
    public void displayProfile() {
        System.out.println("= VENDOR PROFILE =");
        System.out.println("  ID              : " + getEntityID());
        System.out.println("  Name            : " + getName());
        System.out.println("  Vendor Type     : " + vendorType);
        System.out.println("  Capital (UGX)   : " + capitalAmount);
        System.out.println("  Gender          : " + gender);
        System.out.println("  Has Dependants  : " + hasDependants);
        System.out.println("  Residence       : " + placeOfResidence);
        System.out.println("  Assigned Market : " + (assignedMarket != null ? assignedMarket : "Not yet assigned"));
        System.out.println("  Licence Number  : " + (licenceNumber  != null ? licenceNumber  : "Not yet registered"));
        System.out.println("  Status          : " + getStatus());
        System.out.println("  Registered On   : " + getDateRegistered());
    }

    // getStatus() — overrides CustomUser (Polymorphism)
    @Override
    public String getStatus() {
        return licenceNumber != null ? getRawStatus() : "UNREGISTERED";
    }

    // getRole() — overrides CustomUser
    @Override
    public String getRole() { return "VENDOR"; }

    // Priority score for equitable space allocation
    // Female vendors and those with dependants score higher
    // (Based on Whitesell et al. 2025 gender-equity recommendation)
    public double getPriorityScore() {
        double score = 1.0;
        if (gender.equalsIgnoreCase("F"))  score += 0.2;
        if (hasDependants)                 score += 0.1;
        return score;
    }

    // Getters & Setters
    public String  getVendorType()                  { return vendorType; }
    public double  getCapitalAmount()               { return capitalAmount; }
    public String  getGender()                      { return gender; }
    public boolean hasDependants()                  { return hasDependants; }
    public String  getLicenceNumber()               { return licenceNumber; }
    public String  getAssignedMarket()              { return assignedMarket; }
    public void    setAssignedMarket(String market) { this.assignedMarket = market; }
}


